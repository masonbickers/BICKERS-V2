# Clerk application keys (Clerk Dashboard > API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth/complete
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/auth/complete
# Emergency rollback only; leave disabled once Clerk is live.
ALLOW_LEGACY_FIREBASE_LOGIN=false

# Firebase remains the Firestore data layer during the Clerk migration.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=bickers-booking
NEXT_PUBLIC_FIREBASE_API_KEY=
FIREBASE_SERVICE_ACCOUNT_CLIENT_EMAIL=
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY=

# One-time Firebase password-preserving Clerk migration. Get these from
# Firebase Authentication > Users > Password hash parameters; do not commit them.
FIREBASE_AUTH_SIGNER_KEY=
FIREBASE_AUTH_SALT_SEPARATOR=
FIREBASE_AUTH_ROUNDS=
FIREBASE_AUTH_MEM_COST=

# AI assistant and statistics briefing
OPENAI_API_KEY=
OPENAI_STATISTICS_MODEL=gpt-4o-mini

# Vercel Cron authentication
CRON_SECRET=
