rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function isNotDisabled() {
      return isSignedIn();
    }

    function roleValue() {
      return userData() != null && userData().keys().hasAny(["role"])
        ? userData().role
        : "";
    }

    function isPlatformAdmin() {
      return isNotDisabled()
        && roleValue() in [
          "platformAdmin",
          "platformadmin",
          "platform admin",
          "Platform Admin",
          "superAdmin",
          "superadmin",
          "super admin",
          "Super Admin"
        ];
    }

    function isAdmin() {
      return isPlatformAdmin()
        || (
          isNotDisabled()
          && roleValue() in [
            "admin",
            "Admin",
            "companyAdmin",
            "companyadmin",
            "company admin",
            "Company Admin"
          ]
        );
    }

    function canUseSoftware() {
      return isNotDisabled();
    }

    function canAccessCompany(companyId) {
      return canUseSoftware();
    }

    function appAccessEnabled(workspace) {
      return userData() != null
        && userData().keys().hasAny(["appAccess"])
        && userData().appAccess is map
        && userData().appAccess.keys().hasAny([workspace])
        && userData().appAccess[workspace] == true;
    }

    function defaultWorkspaceIs(workspace) {
      return userData() != null
        && userData().keys().hasAny(["defaultWorkspace"])
        && userData().defaultWorkspace == workspace;
    }

    function roleIn(roles) {
      return userData() != null
        && userData().keys().hasAny(["role"])
        && userData().role in roles;
    }

    function isServiceUser() {
      return userData() != null
        && userData().keys().hasAny(["isService"])
        && userData().isService == true;
    }

    function hasUserAccess() {
      return canUseSoftware();
    }

    function hasServiceAccess() {
      return canUseSoftware();
    }

    function isSafeFileSize(maxBytes) {
      return request.resource.size != null && request.resource.size <= maxBytes;
    }

    function isSafeMimeType(allowed) {
      return request.resource.contentType != null
        && request.resource.contentType.matches(allowed);
    }

    match /profilePhotos/{uid}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && (request.auth.uid == uid || isAdmin())
        && isSafeFileSize(10 * 1024 * 1024)
        && isSafeMimeType('image/.*');
    }

    match /companies/{companyId}/profilePhotos/{uid}/{allPaths=**} {
      allow read: if canAccessCompany(companyId);
      allow write: if canAccessCompany(companyId)
        && (request.auth.uid == uid || isAdmin())
        && isSafeFileSize(10 * 1024 * 1024)
        && isSafeMimeType('image/.*');
    }

    match /companies/{companyId}/booking_pdfs/{allPaths=**} {
      allow read: if canAccessCompany(companyId) && hasUserAccess();
      allow write: if canAccessCompany(companyId)
        && hasUserAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf');
    }

    match /companies/{companyId}/quotes/{allPaths=**} {
      allow read: if canAccessCompany(companyId) && hasUserAccess();
      allow write: if canAccessCompany(companyId)
        && hasUserAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|application/vnd\\.openxmlformats-officedocument\\.spreadsheetml\\.sheet|application/vnd\\.ms-excel|text/csv|image/.*|application/octet-stream');
    }

    match /companies/{companyId}/job_attachments/{jobId}/{allPaths=**} {
      allow read: if canAccessCompany(companyId) && hasUserAccess();
      allow write: if canAccessCompany(companyId)
        && hasUserAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|image/.*|application/octet-stream');
    }

    match /companies/{companyId}/maintenance-quotes/{allPaths=**} {
      allow read: if canAccessCompany(companyId) && hasServiceAccess();
      allow write: if canAccessCompany(companyId)
        && hasServiceAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|image/.*|application/octet-stream');
    }

    match /companies/{companyId}/vehicles/{vehicleId}/{field}/{allPaths=**} {
      allow read: if canAccessCompany(companyId) && hasServiceAccess();
      allow write: if canAccessCompany(companyId)
        && hasServiceAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|image/.*|application/octet-stream');
    }

    match /companies/{companyId}/hr/contracts/{employeeRef}/{allPaths=**} {
      allow read: if canAccessCompany(companyId) && isAdmin();
      allow write: if canAccessCompany(companyId)
        && isAdmin()
        && isSafeFileSize(25 * 1024 * 1024);
    }

    match /recce-photos/{uid}/{bookingId}/{allPaths=**} {
      allow read: if hasUserAccess();
      allow write: if hasUserAccess()
        && request.auth.uid == uid
        && isSafeFileSize(20 * 1024 * 1024)
        && isSafeMimeType('image/.*');
    }

    match /booking_pdfs/{allPaths=**} {
      allow read: if hasUserAccess();
      allow write: if hasUserAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf');
    }

    match /quotes/{allPaths=**} {
      allow read: if hasUserAccess();
      allow write: if hasUserAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|application/vnd\\.openxmlformats-officedocument\\.spreadsheetml\\.sheet|application/vnd\\.ms-excel|text/csv|image/.*|application/octet-stream');
    }

    match /job_attachments/{jobId}/{allPaths=**} {
      allow read: if hasUserAccess();
      allow write: if hasUserAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|image/.*|application/octet-stream');
    }

    match /maintenance-quotes/{allPaths=**} {
      allow read: if hasServiceAccess();
      allow write: if hasServiceAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|image/.*|application/octet-stream');
    }

    match /vehicles/{vehicleId}/{field}/{allPaths=**} {
      allow read: if hasServiceAccess();
      allow write: if hasServiceAccess()
        && isSafeFileSize(25 * 1024 * 1024)
        && isSafeMimeType('application/pdf|image/.*|application/octet-stream');
    }

    match /hr/contracts/{employeeRef}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin()
        && isSafeFileSize(25 * 1024 * 1024);
    }

    match /images/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin()
        && isSafeFileSize(10 * 1024 * 1024)
        && isSafeMimeType('image/.*');
    }

    match /debug/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
