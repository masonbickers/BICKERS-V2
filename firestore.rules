rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasLegacyMobileAccess() {
      return isSignedIn();
    }

    function userDocExists() {
      return isSignedIn();
    }

    function isNotDisabled() {
      return activeUserDocExists();
    }

    function activeUserDocExists() {
      return isSignedIn();
    }

    function currentUserCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function existingDocBelongsToCurrentCompany() {
      return activeUserDocExists();
    }

    function incomingDocBelongsToCurrentCompany() {
      return activeUserDocExists();
    }

    // TEMPORARY EMERGENCY READ FALLBACK - REMOVE AFTER TENANT QUERY MIGRATION
    function canEmergencyReadBickersBusinessData() {
      return activeUserDocExists();
    }

    function canReadTenantBusinessDoc() {
      return activeUserDocExists();
    }

    function currentUserAppAccessEnabled(workspace) {
      return userDocExists()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["appAccess"])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appAccess is map
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appAccess.keys().hasAny([workspace])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appAccess[workspace] == true;
    }

    function currentUserDefaultWorkspaceIs(workspace) {
      return userDocExists()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["defaultWorkspace"])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.defaultWorkspace == workspace;
    }

    function currentUserRoleIn(roles) {
      return userDocExists()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["role"])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function isPlatformAdmin() {
      return activeUserDocExists()
        && currentUserRoleIn([
          "platformAdmin",
          "platformadmin",
          "platform admin",
          "Platform Admin",
          "superAdmin",
          "superadmin",
          "super admin",
          "Super Admin"
        ]);
    }

    function isAdmin() {
      return isPlatformAdmin()
        || (
          activeUserDocExists()
          && currentUserRoleIn([
            "admin",
            "Admin",
            "companyAdmin",
            "companyadmin",
            "company admin",
            "Company Admin"
          ])
        );
    }

    function canManageTenantData() {
      return activeUserDocExists();
    }

    function canUseSoftware() {
      return activeUserDocExists();
    }

    function canReadUserTenantDoc() {
      return canUseSoftware() && canReadTenantBusinessDoc();
    }

    function canCreateUserTenantDoc() {
      return canUseSoftware() && incomingDocBelongsToCurrentCompany();
    }

    function canUpdateUserTenantDoc() {
      return canUseSoftware()
        && existingDocBelongsToCurrentCompany()
        && incomingDocBelongsToCurrentCompany();
    }

    function canDeleteUserTenantDoc() {
      return canUseSoftware() && existingDocBelongsToCurrentCompany();
    }

    function canReadServiceTenantDoc() {
      return canUseSoftware() && canReadTenantBusinessDoc();
    }

    function canCreateServiceTenantDoc() {
      return canUseSoftware() && incomingDocBelongsToCurrentCompany();
    }

    function canUpdateServiceTenantDoc() {
      return canUseSoftware()
        && existingDocBelongsToCurrentCompany()
        && incomingDocBelongsToCurrentCompany();
    }

    function canDeleteServiceTenantDoc() {
      return canUseSoftware() && existingDocBelongsToCurrentCompany();
    }

    function canReadAnyWorkspaceTenantDoc() {
      return canUseSoftware() && canReadTenantBusinessDoc();
    }

    function canCreateAnyWorkspaceTenantDoc() {
      return canUseSoftware() && incomingDocBelongsToCurrentCompany();
    }

    function canUpdateAnyWorkspaceTenantDoc() {
      return canUseSoftware()
        && existingDocBelongsToCurrentCompany()
        && incomingDocBelongsToCurrentCompany();
    }

    function canDeleteAnyWorkspaceTenantDoc() {
      return canUseSoftware() && existingDocBelongsToCurrentCompany();
    }

    function canUseCalendar() {
      return canUseSoftware();
    }

    function currentUserIsService() {
      return userDocExists()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["isService"])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isService == true;
    }

    function hasUserAccess() {
      return activeUserDocExists();
    }

    function hasServiceAccess() {
      return activeUserDocExists();
    }

    function isOwnUserDoc(uid) {
      return activeUserDocExists() && request.auth.uid == uid;
    }

    function isOwnEmployeeDoc() {
      return isSignedIn()
        && (
          resource.data.uid == request.auth.uid
          || resource.data.authUid == request.auth.uid
          || resource.id == request.auth.uid
        );
    }

    function isOwnEmployeeDocAfterWrite() {
      return isSignedIn()
        && (
          request.resource.data.uid == request.auth.uid
          || request.resource.data.authUid == request.auth.uid
          || resource.id == request.auth.uid
        );
    }

    function keepsOwnEmployeeIdentity() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.authUid == resource.data.authUid
        && request.resource.data.email == resource.data.email;
    }

    function matchesAuthEmail(email) {
      return isSignedIn()
        && email is string
        && request.auth.token.email is string
        && email == request.auth.token.email;
    }

    function isHolidayOwner() {
      return isSignedIn()
        && (
          resource.data.requestedByUid == request.auth.uid
          || matchesAuthEmail(resource.data.requestedByEmail)
        );
    }

    function isHolidayOwnerOnCreate() {
      return isSignedIn()
        && (
          request.resource.data.requestedByUid == request.auth.uid
          || matchesAuthEmail(request.resource.data.requestedByEmail)
        );
    }

    function keepsHolidayOwnerIdentity() {
      return request.resource.data.requestedByUid == resource.data.requestedByUid
        && request.resource.data.requestedByEmail == resource.data.requestedByEmail;
    }

    function isShiftChangeOwner() {
      return isSignedIn()
        && (
          resource.data.requestedByUid == request.auth.uid
          || matchesAuthEmail(resource.data.requestedByEmail)
        );
    }

    function isShiftChangeOwnerOnCreate() {
      return isSignedIn()
        && (
          request.resource.data.requestedByUid == request.auth.uid
          || matchesAuthEmail(request.resource.data.requestedByEmail)
        );
    }

    function keepsShiftChangeOwnerIdentity() {
      return request.resource.data.requestedByUid == resource.data.requestedByUid
        && request.resource.data.requestedByEmail == resource.data.requestedByEmail;
    }

    function shiftChangeOwnerCancelOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "status",
        "updatedAt"
      ]);
    }

    function isApprovedHolidayRecord() {
      return resource.data.approved == true
        || resource.data.status == "approved"
        || resource.data.approvalStatus == "approved"
        || resource.data.state == "approved"
        || resource.data.leaveStatus == "approved"
        || resource.data.holidayStatus == "approved";
    }

    function isApprovedHolidayAfterWrite() {
      return request.resource.data.approved == true
        || request.resource.data.status == "approved"
        || request.resource.data.approvalStatus == "approved"
        || request.resource.data.state == "approved"
        || request.resource.data.leaveStatus == "approved"
        || request.resource.data.holidayStatus == "approved";
    }

    function hasBookingAuditFieldsOnCreate() {
      return isSignedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.lastEditedByUid == request.auth.uid;
    }

    function keepsBookingAuditIdentity() {
      return request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          resource.data.createdByUid == null
          || request.resource.data.createdByUid == resource.data.createdByUid
        );
    }

    function keepsTimesheetIdentity() {
      return request.resource.data.employeeCode == resource.data.employeeCode
        && request.resource.data.employeeName == resource.data.employeeName
        && request.resource.data.weekStart == resource.data.weekStart;
    }

    function keepsTimesheetQueryIdentity() {
      return request.resource.data.timesheetId == resource.data.timesheetId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdByRole == resource.data.createdByRole;
    }

    function timesheetQueryInCurrentCompany(queryId) {
      return exists(/databases/$(database)/documents/timesheetQueries/$(queryId));
    }

    function userOnlyFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "name",
        "phone",
        "updatedAt",
        "phoneVerified",
        "phoneVerifiedAt",
        "mfaMethod",
        "mfaEnabled",
        "mfaPhoneNumber",
        "mfaSecret",
        "mfaEnrolledAt",
        "mfaResetRequired"
      ]);
    }

    match /users/{uid} {
      allow read: if isOwnUserDoc(uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isOwnUserDoc(uid) && userOnlyFieldsChanged());
      allow delete: if isAdmin();
    }

    match /mfaSecrets/{uid} {
      allow read, write: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /loginSecurityLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /passkeyCredentials/{credentialId} {
      allow read, write: if false;
    }

    match /passkeyChallenges/{challengeId} {
      allow read, write: if false;
    }

    match /setupCodeRateLimits/{docId} {
      allow read, write: if false;
    }

    match /employees/{employeeId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if activeUserDocExists();
      allow update: if activeUserDocExists();
      allow delete: if activeUserDocExists();
    }

    match /bookings/{bookingId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /notes/{noteId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /contacts/{contactId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /deletedBookings/{docId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /appState/{docId} {
      allow read, write: if hasUserAccess();
    }

    match /notes/{noteId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /recces/{docId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /holidays/{holidayId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /deletedHolidays/{holidayId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /shiftChangeRequests/{requestId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /hr/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /timesheets/{timesheetId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if activeUserDocExists();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /timesheetQueries/{queryId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if activeUserDocExists();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /timesheetQueries/{queryId}/messages/{messageId} {
      allow read, write: if canUseSoftware();
    }

    match /sickLeave/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /uCraneFreelancers/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /lorries/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /invoiceQueue/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /vehicles/{vehicleId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /equipment/{equipmentId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /maintenance/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /maintenanceJobs/{jobId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /maintenanceBookings/{bookingId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateAnyWorkspaceTenantDoc();
      allow update: if canUpdateAnyWorkspaceTenantDoc();
      allow delete: if canDeleteAnyWorkspaceTenantDoc();
    }

    match /vehicleChecks/{docId} {
      allow read: if canReadAnyWorkspaceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /defects/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /workBookings/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /serviceRecords/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /defectReports/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /motPreChecks/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /vehiclePrepRecords/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /vehicleIssues/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /vehicleUsageNotes/{docId} {
      allow read: if canReadServiceTenantDoc();
      allow create: if canCreateServiceTenantDoc();
      allow update: if canUpdateServiceTenantDoc();
      allow delete: if canDeleteServiceTenantDoc();
    }

    match /hsRegister/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /hsCheckRecords/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /ppeIssueRecords/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /employeeTrainingRecords/{docId} {
      allow read: if canReadUserTenantDoc();
      allow create: if canCreateUserTenantDoc();
      allow update: if canUpdateUserTenantDoc();
      allow delete: if canDeleteUserTenantDoc();
    }

    match /settings/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }
  }
}
