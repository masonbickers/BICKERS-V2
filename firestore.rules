rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return isSignedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function activeUser() {
      return userDocExists()
        && userData().isEnabled == true
        && (!userData().keys().hasAny(['credentialResetRequired'])
          || userData().credentialResetRequired == false)
        && userData().companyId is string
        && userData().companyId.size() > 0
        && userData().role in ['user', 'admin', 'platformAdmin'];
    }

    function companyId() {
      return userData().companyId;
    }

    function isAdmin() {
      return activeUser() && userData().role in ['admin', 'platformAdmin'];
    }

    function writesOpen() {
      let settingsPath = /databases/$(database)/documents/settings/platform;
      return !exists(settingsPath) || get(settingsPath).data.maintenanceMode != true;
    }

    // Platform administrators deliberately remain tenant-bound in client rules.
    // Cross-company actions are available only through protected Admin SDK APIs.
    function existingTenant() {
      return activeUser()
        && resource.data.companyId is string
        && resource.data.companyId == companyId();
    }

    function incomingTenant() {
      return activeUser()
        && request.resource.data.companyId is string
        && request.resource.data.companyId == companyId();
    }

    function keepsTenant() {
      return existingTenant() && incomingTenant()
        && request.resource.data.companyId == resource.data.companyId;
    }

    function workspaceEnabled(workspace) {
      return activeUser()
        && userData().appAccess is map
        && userData().appAccess[workspace] == true;
    }

    function canReadTenant(workspace) {
      return existingTenant() && (isAdmin() || workspaceEnabled(workspace));
    }

    function adminCreate() {
      return writesOpen() && isAdmin() && incomingTenant();
    }

    function adminUpdate() {
      return writesOpen() && isAdmin() && keepsTenant();
    }

    function adminDelete() {
      return writesOpen() && isAdmin() && existingTenant();
    }

    function authEmail() {
      return isSignedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : '';
    }

    function owns(data) {
      return activeUser() && (
        (data.keys().hasAny(['ownerUid']) && data.ownerUid == request.auth.uid)
        || (data.keys().hasAny(['requestedByUid']) && data.requestedByUid == request.auth.uid)
        || (data.keys().hasAny(['createdByUid']) && data.createdByUid == request.auth.uid)
        || (data.keys().hasAny(['reportedByUid']) && data.reportedByUid == request.auth.uid)
        || (data.keys().hasAny(['submittedByUid']) && data.submittedByUid == request.auth.uid)
        || (data.keys().hasAny(['ownerEmail']) && data.ownerEmail == authEmail())
        || (data.keys().hasAny(['requestedByEmail']) && data.requestedByEmail == authEmail())
      );
    }

    function ownCreate() {
      return writesOpen() && incomingTenant() && owns(request.resource.data);
    }

    function ownUpdate() {
      return writesOpen() && keepsTenant() && owns(resource.data) && owns(request.resource.data);
    }

    function requestFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'startDate', 'endDate', 'holidayDateKeys', 'startHalfDay', 'startAMPM',
        'endHalfDay', 'endAMPM', 'holidayReason', 'paidStatus', 'date',
        'startTime', 'finishTime', 'reason', 'status', 'updatedAt', 'cancelledAt'
      ]) && request.resource.data.status in ['requested', 'cancelled'];
    }

    function ownProfileFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name', 'phone', 'updatedAt', 'phoneVerified', 'phoneVerifiedAt',
        'mfaMethod', 'mfaEnabled', 'mfaPhoneNumber', 'mfaEnrolledAt',
        'mfaResetRequired'
      ]);
    }

    function reportCreate() {
      return writesOpen() && incomingTenant() && owns(request.resource.data)
        && request.resource.data.createdAt != null;
    }

    match /users/{uid} {
      allow read: if activeUser() && (
        request.auth.uid == uid
        || (isAdmin() && resource.data.companyId == companyId())
      );
      allow create: if adminCreate();
      allow update: if adminUpdate()
        || (writesOpen() && activeUser() && request.auth.uid == uid
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.role == resource.data.role
          && request.resource.data.isEnabled == resource.data.isEnabled
          && request.resource.data.credentialResetRequired == resource.data.credentialResetRequired
          && ownProfileFieldsOnly());
      allow delete: if adminDelete();
    }

    match /employees/{id} {
      allow read: if canReadTenant('user') || canReadTenant('service');
      allow create: if adminCreate();
      allow update: if adminUpdate();
      allow delete: if adminDelete();
    }

    match /bookings/{id} {
      allow read: if canReadTenant('user') || canReadTenant('service');
      allow create: if adminCreate();
      allow update: if adminUpdate();
      allow delete: if adminDelete();
    }

    match /appState/{id} {
      allow read: if canReadTenant('user') || canReadTenant('service');
      allow create: if adminCreate();
      allow update: if adminUpdate();
      allow delete: if adminDelete();
    }

    match /holidays/{id} {
      allow read: if canReadTenant('user');
      allow create: if adminCreate() || ownCreate();
      allow update: if adminUpdate() || (ownUpdate() && requestFieldsOnly());
      allow delete: if adminDelete();
    }

    match /shiftChangeRequests/{id} {
      allow read: if canReadTenant('user');
      allow create: if adminCreate() || ownCreate();
      allow update: if adminUpdate() || (ownUpdate() && requestFieldsOnly());
      allow delete: if adminDelete();
    }

    match /timesheets/{id} {
      allow read: if canReadTenant('user');
      allow create: if adminCreate() || ownCreate();
      allow update: if adminUpdate() || ownUpdate();
      allow delete: if adminDelete() || (existingTenant() && owns(resource.data));
    }

    match /timesheetQueries/{queryId} {
      allow read: if canReadTenant('user');
      allow create: if adminCreate() || ownCreate();
      allow update: if adminUpdate() || ownUpdate();
      allow delete: if adminDelete();

      match /messages/{messageId} {
        function parentQuery() {
          return get(/databases/$(database)/documents/timesheetQueries/$(queryId)).data;
        }
        allow read: if activeUser()
          && parentQuery().companyId == companyId()
          && (isAdmin() || workspaceEnabled('user'));
        allow create: if writesOpen() && activeUser()
          && parentQuery().companyId == companyId()
          && request.resource.data.companyId == companyId()
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /defectReports/{id} {
      allow read: if canReadTenant('service');
      allow create: if adminCreate() || reportCreate();
      allow update: if adminUpdate();
      allow delete: if adminDelete();
    }

    match /vehicleIssues/{id} {
      allow read: if canReadTenant('service');
      allow create: if adminCreate() || reportCreate();
      allow update: if adminUpdate();
      allow delete: if adminDelete();
    }

    match /hsRegister/{id} {
      allow read: if canReadTenant('user');
      allow create: if adminCreate() || reportCreate();
      allow update: if adminUpdate();
      allow delete: if adminDelete();
    }

    match /{collection}/{id} {
      allow read: if collection in [
          'clients', 'clientEmails', 'contacts', 'deletedBookings', 'deletedQuotes',
          'holidayAllowances', 'holidays', 'hrDocuments', 'invoiceQueue', 'jobSheets',
          'notes', 'recces', 'shiftChangeRequests', 'sickLeave', 'timesheetQueries',
          'timesheets', 'uCraneFreelancers'
        ] && canReadTenant('user');
      allow create: if collection in [
          'clients', 'clientEmails', 'contacts', 'deletedBookings', 'deletedQuotes',
          'holidayAllowances', 'hrDocuments', 'invoiceQueue', 'jobSheets', 'notes',
          'recces', 'sickLeave', 'uCraneFreelancers'
        ] && adminCreate();
      allow update: if collection in [
          'clients', 'clientEmails', 'contacts', 'deletedBookings', 'deletedQuotes',
          'holidayAllowances', 'hrDocuments', 'invoiceQueue', 'jobSheets', 'notes',
          'recces', 'sickLeave', 'uCraneFreelancers'
        ] && adminUpdate();
      allow delete: if collection in [
          'clients', 'clientEmails', 'contacts', 'deletedBookings', 'deletedQuotes',
          'holidayAllowances', 'hrDocuments', 'invoiceQueue', 'jobSheets', 'notes',
          'recces', 'sickLeave', 'uCraneFreelancers'
        ] && adminDelete();
    }

    match /{collection}/{id} {
      allow read: if collection in [
          'defects', 'employeeTrainingRecords', 'equipment', 'hsCheckRecords',
          'lorries', 'maintenance', 'maintenanceBookings', 'maintenanceJobs',
          'motPreChecks', 'ppeIssueRecords', 'serviceRecords', 'vehicleChecks',
          'vehiclePrepRecords', 'vehicleUsageNotes', 'vehicles', 'workBookings'
        ] && canReadTenant('service');
      allow create: if collection in [
          'defects', 'employeeTrainingRecords', 'equipment', 'hsCheckRecords',
          'lorries', 'maintenance', 'maintenanceBookings', 'maintenanceJobs',
          'motPreChecks', 'ppeIssueRecords', 'serviceRecords', 'vehicleChecks',
          'vehiclePrepRecords', 'vehicleUsageNotes', 'vehicles', 'workBookings'
        ] && adminCreate();
      allow update: if collection in [
          'defects', 'employeeTrainingRecords', 'equipment', 'hsCheckRecords',
          'lorries', 'maintenance', 'maintenanceBookings', 'maintenanceJobs',
          'motPreChecks', 'ppeIssueRecords', 'serviceRecords', 'vehicleChecks',
          'vehiclePrepRecords', 'vehicleUsageNotes', 'vehicles', 'workBookings'
        ] && adminUpdate();
      allow delete: if collection in [
          'defects', 'employeeTrainingRecords', 'equipment', 'hsCheckRecords',
          'lorries', 'maintenance', 'maintenanceBookings', 'maintenanceJobs',
          'motPreChecks', 'ppeIssueRecords', 'serviceRecords', 'vehicleChecks',
          'vehiclePrepRecords', 'vehicleUsageNotes', 'vehicles', 'workBookings'
        ] && adminDelete();
    }

    match /settings/{id} {
      allow read: if isAdmin();
      allow write: if writesOpen() && isAdmin();
    }

    match /platformCompanies/{id} {
      allow read, write: if false;
    }

    match /mfaSecrets/{id} {
      allow read, write: if false;
    }

    match /adminAuditLogs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /loginSecurityLogs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /apiRateLimits/{id} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
