{
  "name": "bickers-booking",
  "version": "3.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/prepare-next-dev-cache.mjs",
    "dev": "next dev",
    "predev:turbo": "node scripts/prepare-next-dev-cache.mjs",
    "dev:turbo": "next dev --turbopack",
    "prebuild": "node scripts/write-build-info.mjs",
    "build": "next build",
    "postbuild": "node scripts/check-build-budgets.mjs",
    "build:budget": "node scripts/check-build-budgets.mjs",
    "start": "next start",
    "lint": "eslint .",
    "check:secrets": "node scripts/check-secret-files.mjs",
    "check:secrets:history": "node scripts/check-secret-files.mjs --history",
    "audit:access": "node scripts/security-access-audit.mjs",
    "audit:auth-repair": "node scripts/auth-access-repair-report.mjs",
    "test:access": "node --test tests/accessControl.test.mjs",
    "test:resource-locks": "node scripts/test-resource-locks.mjs",
    "migrate:employee-access": "node scripts/migrate-employee-access.mjs",
    "migrate:company": "node scripts/backfill-company-id.mjs",
    "migrate:storage": "node scripts/migrate-storage-paths.mjs",
    "migrate:quote-assets": "node scripts/backfill-quote-assets.mjs",
    "maintenance": "node scripts/set-maintenance-mode.mjs",
    "incident:contain": "node scripts/contain-credential-incident.mjs",
    "incident:disable-legacy-auth": "node scripts/disable-legacy-firebase-auth.mjs",
    "test:rules": "firebase emulators:exec --only firestore,storage --project demo-bickers-booking \"node --test tests/firebaseRules.test.mjs\"",
    "test:rollback-rules": "firebase emulators:exec --config firebase.secure-rollback.json --only firestore,storage --project demo-bickers-booking-rollback \"node --test tests/firebaseRollbackRules.test.mjs\"",
    "test:api": "node --test tests/apiSecurity.test.mjs",
    "test:unit": "node --test tests/accessControl.test.mjs tests/apiSecurity.test.mjs tests/dateNormalization.test.mjs tests/migration.test.mjs tests/quoteLifecycle.test.mjs",
    "test:all": "npm run test:unit && npm run test:resource-locks && npm run test:rules && npm run test:rollback-rules"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.18",
    "@fullcalendar/core": "^6.1.18",
    "@fullcalendar/daygrid": "^6.1.18",
    "@fullcalendar/interaction": "^6.1.18",
    "@fullcalendar/react": "^6.1.18",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "firebase": "^11.10.0",
    "firebase-admin": "13.10.0",
    "framer-motion": "^12.20.1",
    "lucide-react": "^0.542.0",
    "next": "15.5.9",
    "openai": "^5.1.1",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-big-calendar": "^1.18.0",
    "react-calendar": "^5.1.0",
    "react-dom": "^19.0.0",
    "react-multi-date-picker": "^4.5.2",
    "recharts": "^2.15.3",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@firebase/rules-unit-testing": "4.0.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "firebase-tools": "14.16.0"
  }
}
