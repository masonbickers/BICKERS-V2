{
  "name": "bickers-booking",
  "version": "3.0.5",
  "private": true,
  "scripts": {
    "predev": "node scripts/prepare-next-dev-cache.mjs",
    "dev": "next dev",
    "predev:turbo": "node scripts/prepare-next-dev-cache.mjs",
    "dev:turbo": "next dev --turbopack",
    "prebuild": "node scripts/write-build-info.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:access": "node scripts/security-access-audit.mjs",
    "audit:auth-repair": "node scripts/auth-access-repair-report.mjs",
    "audit:styles": "node scripts/style-audit.mjs",
    "audit:styles:check": "node scripts/style-audit.mjs --check",
    "audit:styles:strict": "node scripts/style-audit.mjs --strict",
    "styles:centralize-colours": "node scripts/centralize-style-colours.mjs",
    "styles:centralize-values": "node scripts/centralize-style-values.mjs",
    "test:access": "node --test tests/accessControl.test.mjs",
    "test:timesheets": "node --test tests/timesheetDetail.test.mjs",
    "test:timesheet-migration": "node --test tests/timesheetMigration.test.mjs",
    "test:timesheet-rules": "node scripts/run-timesheet-rules-tests.mjs",
    "test:statistics": "node --test tests/statisticsFilters.test.mjs",
    "migrate:timesheets": "node scripts/migrate-timesheet-contract.mjs",
    "migrate:employee-access": "node scripts/migrate-employee-access.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.18",
    "@fullcalendar/core": "^6.1.18",
    "@fullcalendar/daygrid": "^6.1.18",
    "@fullcalendar/interaction": "^6.1.18",
    "@fullcalendar/react": "^6.1.18",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "firebase": "^11.10.0",
    "framer-motion": "^12.20.1",
    "lucide-react": "^0.542.0",
    "next": "^15.4.5",
    "openai": "^5.1.1",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-big-calendar": "^1.18.0",
    "react-calendar": "^5.1.0",
    "react-dom": "^19.0.0",
    "react-multi-date-picker": "^4.5.2",
    "recharts": "^2.15.3",
    "speakeasy": "^2.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@firebase/rules-unit-testing": "^4.0.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.0"
  },
  "description": "Internal operations platform for Bickers Action. The app manages bookings, diary views, jobs, HR, timesheets, vehicles, equipment, maintenance, finance queues, H&S records, U-Crane workflows, security setup, and platform/admin tooling.",
  "main": "firebaseConfig.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
